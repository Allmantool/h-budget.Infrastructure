# Safe local placeholders for Docker Compose.
# Copy to .env and replace machine-specific paths and secrets locally.

ASPNETCORE_ENVIRONMENT=Docker
GITHUB_RUN_ID=local
PULL_REQUEST_ID=0
PULL_REQUEST_SOURCE_BRANCH=local
PULL_REQUEST_TARGET_BRANCH=main
HOME_SERVER=localhost
HOSTNAME=localhost

# Sensitive values. Use local-only secrets; do not commit real values.
MONGO_DB_PASSWORD=change-me-local-only
SQL_PASSWORD=change-me-local-only
GRAFANA_PASSWORD=change-me-local-only
SEQ_DEFAULT_PASSWORD=change-me-local-only
SEQ_DEFAULT_USER=Y
SONAR_TOKEN=
NUKEEPER_TOKEN=
UI_CERTIFICATE_PASSWORD=change-me-local-only
GATEWAY_API_CERTIFICATE_PASSWORD=change-me-local-only

# SQL Server
SQL_SERVER=homebudget-sql-server
SQL_SERVER_2022_PORT=1433
SQL_SERVER_2025_PORT=1433
SQL_WMS_2022_VERSION=2022-latest
SQL_WMS_2025_VERSION=2025-latest
SQL_WMS_VOLUME_2022_PATH_BACKUPS=./data/mssql/backups
SQL_WMS_VOLUME_2022_PATH=./data/mssql/data
SQL_WMS_VOLUME_2022_PATH_SYSTEM=./data/mssql/system
SQL_WMS_VOLUME_2025_PATH_BACKUPS=./data/mssql/backups
SQL_WMS_VOLUME_2025_PATH=./data/mssql/data
SQL_WMS_VOLUME_2025_PATH_SYSTEM=./data/mssql/system

# Application image versions
RATES_API_IMAGE_V=0.0.363
ACCOUNTING_API_IMAGE_V=0.0.251
ACCOUNTING_PAYMENTS_CONSUMER_WORKER_IMAGE_V=0.0.1
UI_IMAGE_V=0.0.57
GATEWAY_API_IMAGE_V=0.0.59
PAYMENT_CONSUMERS_AMOUNT=1

# Application config bind mounts
RATES_API_JSON_PATH=../Api/HomeBudget-Rates-Api/HomeBudget.Rates.Api/appsettings.json
ACCOUNTING_API_JSON_PATH=../Api/HomeBudget-Accounting-Api/HomeBudget.Accounting.Api/appsettings.json
ACCOUNTING_PAYMENTS_CONSUMER_WORKER_JSON_PATH=../Api/HomeBudget-Accounting-Api/HomeBudget.Accounting.Payments.Consumer.Worker/appsettings.json
UI_JSON_PATH=../UI/src/assets/config.json
GATEWAY_API_JSON_PATH=../Gateways/HomeBudget-Backend-Gateway/HomeBudget.Backend.Gateway/appsettings.json
GATEWAY_API_OCELOT_PATH=../Gateways/HomeBudget-Backend-Gateway/HomeBudget.Backend.Gateway/ocelot.json

# Certificates. Keep certificate files local and ignored.
UI_CERTIFICATE_PATH=./certs/ui.crt
UI_CERTIFICATE_KEY_PATH=./certs/ui.key
UI_CERTIFICATE_NAME=ui.crt
UI_CERTIFICATE_KEY_NAME=ui.key
GATEWAY_API_CERTIFICATE_PATH=./certs/hbudgetcert.pfx
GATEWAY_API_CERTIFICATE_NAME=hbudgetcert.pfx

# Infrastructure config bind mounts
FLYWAY_SCRIPTS_PATH=../Scripts/ms-sql
FLYWAY_CONFIG_PATH=../Configurations/flyway
KAFKA_INIT_SCRIPT_PATH=../Scripts/kafka-init.sh
NGINX_CONFIG=../Configurations/nginx.conf
PROMETHEUS_CONFIG=../Configurations/Prometheus/prometheus.yml
PROMETHEUS_ALERT_RULES=../Configurations/Prometheus/alerts.yml
GRAFANA_DATASOURCES_CONFIG=../Configurations/Grafana/datasources/datasources.yaml
GRAFANA_DASHBOARDS_PROVISIONING=../Configurations/Grafana/Provisioning/dashboards.yaml
GRAFANA_DASHBOARDS_PATH=../Configurations/Grafana/dashboards
GRAFANA_CONFIG=../Configurations/Grafana/grafana-provisioning.yml
GRAFANA_CONFIG_FOLDER=../Configurations/Grafana/Provisioning
GF_ALLOY_CONFIG=../Configurations/Grafana/alloy/config.alloy
GF_LOKI_CONFIG=../Configurations/Grafana/loki/loki.yaml
GF_TEMPO_CONFIG=../Configurations/Grafana/tempo.yaml
GF_PATHS_LOGS=../Configurations/Grafana/Log
GF_STORAGE=../Configurations/Grafana/Lib
GF_PATHS_PROVISIONING=../Configurations/Grafana/Provisioning
DOCKER_NODE_PATHS_LOGS=/

# Optional legacy bind mounts. Prefer named volumes unless these are intentionally needed.
MONGO_DB_VOLUME_PATH=./data/mongo
EVENT_DB_VOLUME_PATH=./data/eventstore
EVENT_DB_LOG_PATH=./data/eventstore-logs
KAFKA_STORE=./data/kafka
SEQ_VOLUME_PATH=./data/seq
PROMETHEUS_DATA=./data/prometheus
ELASTIC_VOLUME_PATH=./data/elastic
